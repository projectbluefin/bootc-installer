{
  "app-id": "org.xfceinstaller.Installer",
  "runtime": "org.gnome.Platform",
  "runtime-version": "46",
  "sdk": "org.gnome.Sdk",
  "command": "xfce-bootc-installer",
  "finish-args": [
    "--share=network",
    "--share=ipc",
    "--socket=wayland",
    "--socket=fallback-x11",
    "--device=all",
    "--filesystem=host",
    "--talk-name=org.freedesktop.Flatpak",
    "--system-talk-name=org.freedesktop.login1",
    "--system-talk-name=org.freedesktop.PolicyKit1",
    "--allow=devel"
  ],
  "build-options": {
    "env": {
      "PATH": "/app/go/bin:/usr/bin:/bin",
      "GOPATH": "/run/build/go-path",
      "GOCACHE": "/run/build/go-cache",
      "GONOSUMDB": "*",
      "GOFLAGS": "",
      "GOPROXY": "off"
    }
  },
  "modules": [
    {
      "name": "go",
      "buildsystem": "simple",
      "build-commands": [
        "cp -r go /app/go"
      ],
      "sources": [
        {
          "type": "archive",
          "url": "https://go.dev/dl/go1.26.1.linux-amd64.tar.gz",
          "sha256": "031f088e5d955bab8657ede27ad4e3bc5b7c1ba281f05f245bcc304f327c987a",
          "strip-components": 0
        }
      ]
    },
    {
      "name": "fisherman",
      "buildsystem": "simple",
      "build-commands": [
        "go build -C fisherman -o /app/bin/fisherman ./cmd/fisherman"
      ],
      "sources": [
        {
          "type": "dir",
          "path": "../fisherman"
        }
      ]
    },
    {
      "name": "blueprint-compiler",
      "buildsystem": "meson",
      "sources": [
        {
          "type": "git",
          "url": "https://gitlab.gnome.org/GNOME/blueprint-compiler.git",
          "tag": "v0.14.0"
        }
      ]
    },
    {
      "name": "xfce-bootc-installer",
      "buildsystem": "meson",
      "config-opts": [
        "-Dbuild-fisherman=false",
        "-Dvariant=xfce"
      ],
      "build-options": {
        "env": {
          "PATH": "/app/bin:/usr/bin:/bin",
          "GI_TYPELIB_PATH": "/usr/lib/x86_64-linux-gnu/girepository-1.0:/usr/share/gir-1.0"
        }
      },
      "sources": [
        {
          "type": "dir",
          "path": ".."
        }
      ]
    },
    {
      "name": "polkit-action",
      "buildsystem": "simple",
      "build-commands": [
        "install -Dm644 data/polkit/org.xfceinstaller.Installer.policy /app/share/polkit-1/actions/org.xfceinstaller.Installer.policy"
      ],
      "sources": [
        {
          "type": "dir",
          "path": ".."
        }
      ]
    }
  ]
}
