#!/usr/bin/env @PYTHON@
#
# KDE bootc Installer launcher
#
# This is the launcher script for the KDE variant of bootc-installer.
# It sets the appropriate environment variables and launches the installer.

import os
import sys

# Set environment variables for KDE variant
os.environ['BOOTC_APP_ID'] = 'org.kdeinstaller.Installer'
os.environ['BOOTC_VARIANT'] = 'kde'
os.environ['QT_API'] = 'pyqt6'

# Add the package directory to the path
sys.path.insert(0, '@pkgdatadir@')

# Import and run the main application
from bootc_installer.main_qt import main

if __name__ == '__main__':
    from bootc_installer._version import VERSION
    sys.exit(main(VERSION))
