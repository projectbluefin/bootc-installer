using Gtk 4.0;
using Adw 1;

template $BootcDefaultDisk: Adw.Bin {
  halign: fill;
  valign: fill;
  hexpand: true;

  Overlay {
    vexpand: true;
    hexpand: true;

    [overlay]
    Button btn_next {
      visible: false;
      sensitive: false;
      margin-end: 12;
      margin-start: 12;
      icon-name: "go-next-symbolic";
      halign: end;
      valign: center;
      tooltip-text: _("Next");

      styles [
        "suggested-action",
      ]
    }

    [overlay]
    Button btn_exit {
      visible: false;
      margin-end: 12;
      margin-start: 12;
      icon-name: "window-close-symbolic";
      halign: start;
      valign: center;
      tooltip-text: _("Exit installer");

      styles [
        "circular",
        "destructive-action",
      ]
    }

    ScrolledWindow {
      hscrollbar-policy: never;
      vexpand: true;
      hexpand: true;

      Adw.PreferencesPage {
        Adw.PreferencesGroup {
          Adw.Banner battery_banner {
            title: _("Computer is not plugged in — connect power before installing");
            revealed: false;
            button-label: "";
          }
        }

        Adw.PreferencesGroup {
          $BootcPageHeader page_header {
            margin-top: 24;
            icon-name: "vanilla-installer-harddisk-symbolic";
            title: _("Install Location");
            subtitle: _(
              "Select the disk where you want to install. All data on the selected disk will be permanently erased."
            );
          }
        }

        Adw.PreferencesGroup group_disks {}

        Adw.PreferencesGroup {
          Box {
            halign: center;
            spacing: 10;

            Button btn_auto {
              label: _("Use Entire Disk");
              margin-top: 20;
              halign: center;
              sensitive: false;

              styles [
                "pill",
                "suggested-action",
              ]
            }

          }
        }

        Adw.PreferencesGroup {
          styles [
            "error",
          ]

          Box disk_space_err_box {
            visible: false;
            halign: center;
            spacing: 5;

            Image {
              icon-name: "drive-harddisk-symbolic";
            }

            Label disk_space_err_label {
              label: _("You need at least %s of disk space to proceed with the installation");
            }
          }
        }

        Adw.PreferencesGroup {
          title: _("System");

          Adw.ComboRow filesystem_row {
            title: _("Root Filesystem");
            visible: false;
          }

          Adw.Banner fs_tool_error_banner {
            visible: false;
            button-label: "";

            styles [
              "error",
            ]
          }
        }

        Adw.PreferencesGroup {
          title: _("Device Name");
          description: _("Choose a unique name to identify this computer on your network.");

          Adw.EntryRow hostname_entry {
            title: _("Hostname");
          }
        }

        Adw.PreferencesGroup {
          title: _("Data disk (/var) — optional");
          description: _("Use a second disk for home directories, applications, and containers. You can reinstall the OS without losing your data.");

          Adw.SwitchRow var_disk_switch {
            title: _("Use a separate data disk");
          }
        }

        Adw.PreferencesGroup group_var_disks {
          title: _("Select data disk");
          visible: false;
        }

        Adw.PreferencesGroup group_var_disk_existing {
          visible: false;

          Adw.ActionRow var_disk_keep_row {
            title: _("Keep existing data");
            subtitle: _("Mount the disk as-is — files in /var will be preserved");
            activatable-widget: var_disk_keep_switch;

            [suffix]
            Switch var_disk_keep_switch {
              valign: center;
              active: true;
            }
          }
        }
      }
    }
  }
}
