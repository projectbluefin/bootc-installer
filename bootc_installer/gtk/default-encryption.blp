using Gtk 4.0;
using Adw 1;

template $BootcDefaultEncryption: Adw.Bin {
  halign: fill;
  valign: fill;
  hexpand: true;

  Overlay {
    vexpand: true;
    hexpand: true;

    [overlay]
    Button btn_next {
      visible: false;
      margin-end: 12;
      margin-start: 12;
      icon-name: "go-next-symbolic";
      halign: end;
      valign: center;
      tooltip-text: _("Next");

      styles [
        "suggested-action",
      ]
    }

    ScrolledWindow {
      hscrollbar-policy: never;
      vexpand: true;
      hexpand: true;

      Adw.PreferencesPage {
        Adw.PreferencesGroup {
          $TunaPageHeader page_header {
            margin-top: 24;
            icon-name: "channel-secure-symbolic";
            title: _("Disk Encryption");
            subtitle: _("Choose how to protect the data on your disk.");
          }
        }

        Adw.PreferencesGroup {
          Adw.ActionRow {
            title: _("Encrypt this disk");
            subtitle: _("You will need a passphrase each time you turn on your computer.");

            [suffix]
            Switch use_encryption_switch {
              valign: center;
              active: true;
            }

            activatable-widget: use_encryption_switch;
          }

          Adw.PasswordEntryRow encryption_pass_entry {
            title: _("Password");
            sensitive: bind use_encryption_switch.active;
          }

          Adw.PasswordEntryRow encryption_pass_entry_confirm {
            title: _("Confirm Password");
            sensitive: bind use_encryption_switch.active;
          }

          Label strength_label {
            visible: false;
            halign: start;
            margin-start: 12;
            margin-top: 4;
            margin-bottom: 4;
          }

          Adw.ActionRow {
            title: _("Use hardware-backed encryption");
            subtitle: _("The disk unlocks automatically on this hardware. Your passphrase remains as a fallback.");
            sensitive: bind use_encryption_switch.active;

            [suffix]
            Switch tpm2_switch {
              valign: center;
            }

            activatable-widget: tpm2_switch;
          }
        }
      }
    }
  }
}
