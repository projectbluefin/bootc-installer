using Gtk 4.0;
using Adw 1;

template $BootcProgress: Box {
  orientation: vertical;

  Box media_box {
    visible: true;
    vexpand: true;
    margin-start: 40;
    margin-end: 40;
    margin-top: 1;
    margin-bottom: 18;
    height-request: 550;
    orientation: vertical;

    Overlay {
      hexpand: true;
      vexpand: true;

      Adw.Clamp {
        maximum-size: 960;
        tightening-threshold: 720;
        hexpand: true;
        vexpand: true;
        valign: center;

        AspectFrame {
          ratio: 1.777778;
          obey-child: false;
          xalign: 0.5;
          yalign: 0.5;
          hexpand: true;
          vexpand: true;

          Gtk.Video install_video {
            hexpand: true;
            vexpand: true;
            autoplay: true;
            loop: true;

            styles [
              "card",
            ]
          }
        }
      }

      Box video_fallback_box {
        visible: false;
        orientation: vertical;
        valign: center;
        halign: center;
        margin-start: 32;
        margin-end: 32;
        margin-top: 32;
        margin-bottom: 32;
        width-request: 440;

        Box {
          orientation: vertical;
          spacing: 16;
          margin-start: 28;
          margin-end: 28;
          margin-top: 28;
          margin-bottom: 28;

          Picture fallback_dino {
            height-request: 120;
            content-fit: contain;
            can-shrink: true;
          }

          Label {
            label: _("Installation Video Coming Soon!");
            justify: center;
            wrap: true;

            styles [
              "title-4",
            ]
          }

          Label {
            label: _("Installation will continue normally. Feel free to browse around. Rawr.");
            justify: center;
            wrap: true;
            max-width-chars: 44;

            styles [
              "caption",
              "dim-label",
            ]
          }

          Separator {
            orientation: horizontal;
            margin-top: 4;
            margin-bottom: 4;

            styles [
              "dim-label",
            ]
          }

          Label {
            label: _("Get Bluefin gear");
            justify: center;

            styles [
              "caption",
              "dim-label",
            ]
          }

          Picture fallback_store_qr {
            height-request: 160;
            width-request: 160;
            halign: center;
            content-fit: contain;
            can-shrink: true;
          }
        }

        styles [
          "card",
        ]
      }
    }
  }

  Box console_box {
    visible: false;
    vexpand: true;
    margin-start: 40;
    margin-end: 40;
    margin-top: 1;
    margin-bottom: 18;
    height-request: 550;
    orientation: vertical;

    ScrolledWindow {
      vexpand: true;
      hexpand: true;
      margin-top: 12;
      margin-start: 12;
      margin-end: 12;
      margin-bottom: 12;

      TextView log_view {
        editable: false;
        monospace: true;
        wrap-mode: word_char;
        top-margin: 8;
        bottom-margin: 8;
        left-margin: 8;
        right-margin: 8;

        styles ["log-view"]
      }
    }

    styles [
      "card",
    ]
  }

  Box {
    orientation: vertical;
    margin-start: 40;
    margin-end: 40;
    margin-top: 24;

    Box {
      orientation: horizontal;
      spacing: 12;

      Box {
        orientation: vertical;
        spacing: 4;
        halign: start;
        hexpand: true;

        Label progressbar_text {
          wrap: true;
          wrap-mode: word_char;
          xalign: 0;
          halign: start;
          label: _("Installing");

          styles [
            "title-4",
          ]
        }

        Label progress_substep {
          wrap: true;
          wrap-mode: word_char;
          xalign: 0;
          halign: start;
          label: "";

          styles [
            "dim-label",
            "caption",
          ]
        }
      }

      Label progress_percentage {
        halign: end;
        valign: center;
        label: "0%";

        styles [
          "title-3",
        ]
      }
    }

    Box {
      orientation: horizontal;
      spacing: 12;
      margin-top: 4;

      Label progress_elapsed {
        xalign: 0;
        halign: start;
        label: _("0:00 elapsed");

        styles [
          "dim-label",
          "caption",
        ]
      }

      Label progress_eta {
        xalign: 0;
        halign: start;
        label: "";

        styles [
          "dim-label",
          "caption",
        ]
      }

      Box {
        halign: fill;
        hexpand: true;
      }

      Button copy_log_button {
        visible: true;
        icon-name: "edit-copy-symbolic";
        halign: end;
        valign: center;
        tooltip-text: _("Copy Console Log");

        styles [
          "circular",
        ]
      }

      Button console_button {
        visible: true;
        icon-name: "media-view-subtitles-symbolic";
        halign: end;
        valign: center;
        tooltip-text: _("Show Console Output");

        styles [
          "circular",
        ]
      }

      Button media_button {
        visible: false;
        icon-name: "media-playback-start-symbolic";
        halign: end;
        valign: center;
        tooltip-text: _("Show Installation Media");

        styles [
          "circular",
        ]
      }
    }

    ProgressBar progressbar {
      show-text: false;
      margin-top: 12;
      margin-bottom: 40;

      styles [
        "thick-progress",
      ]
    }
  }
}
