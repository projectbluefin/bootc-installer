#!/usr/bin/env @PYTHON@
#
# XFCE bootc Installer launcher
#
# This is the launcher script for the XFCE variant of bootc-installer.
# It sets the appropriate environment variables and launches the installer.

import os
import sys

# Set environment variable to indicate XFCE variant
os.environ['BOOTC_APP_ID'] = 'org.xfceinstaller.Installer'
os.environ['BOOTC_VARIANT'] = 'xfce'

# Add the package directory to the path
sys.path.insert(0, '@pkgdatadir@')

# Import and run the main application
from bootc_installer.main import main

if __name__ == '__main__':
    from bootc_installer._version import VERSION
    sys.exit(main(VERSION))
