<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
<id>org.xfceinstaller.Installer</id>
<metadata_license>CC0-1.0</metadata_license>
<project_license>GPL-3.0-only</project_license>
<name translatable="no">XFCE bootc Installer</name>
<summary>Install TunaOS on your computer</summary>
<description>
  <p>A graphical installer for TunaOS and other bootc-based operating systems, optimized for XFCE desktop.</p>
</description>
<translation type="gettext">bootc-installer</translation>
<icon type="stock">system-software-install</icon>
<content_rating type="oars-1.1"/>
<recommends>
  <control>pointing</control>
  <control>keyboard</control>
  <control>touch</control>
</recommends>
<requires>
  <display_length compare="ge">768</display_length>
</requires>
<releases>
  <release version="0.1.0" date="2026-03-27">
    <description>
      <p>First release - XFCE variant</p>
    </description>
  </release>
</releases>
</component>
